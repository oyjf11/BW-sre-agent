{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".vibe-workflow/templates/*.md"
  ],
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls*": "allow",
      "find *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "cat *": "allow",
      "pnpm lint*": "allow",
      "pnpm typecheck*": "allow",
      "pnpm test*": "allow",
      "pnpm build*": "allow",
      "npm run lint*": "allow",
      "npm run test*": "allow",
      "npm run build*": "allow",
      "npx playwright test*": "ask",
      "rm *": "deny",
      "rm -rf *": "deny",
      "git reset --hard*": "deny",
      "git push --force*": "deny"
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "pnpm lint*": "allow",
          "pnpm typecheck*": "allow",
          "pnpm test*": "allow",
          "pnpm build*": "allow",
          "npm run lint*": "allow",
          "npm run test*": "allow",
          "npm run build*": "allow",
          "npx playwright test*": "ask",
          "rm *": "deny",
          "rm -rf *": "deny"
        }
      }
    }
  },
  "command": {
    "frontend-bug": {
      "description": "Run the controlled frontend bug repair workflow through frontend-bug-orchestrator.",
      "agent": "frontend-bug-orchestrator",
      "template": "Use frontend-bug-orchestrator to process this frontend bug under the staged state machine, contract, todo gates and subagent permissions. Bug input:\n\n$ARGUMENTS"
    }
  }
}
