.flex-bar
  display: flex;
// 表单提示
.form-item-tips
  margin-left: 20px;
  color: #999;
  font-size: 14px;
.form-tips-btn
  margin-left: 20px;
  &:hover
    color: #0081df;
.pub-form-wrap
  padding: 20px 0;
// 公共表单样式
.pub-form
  padding-left:20px;
  padding-right: 40px;
  padding-bottom: 20px;
  .el-input,.el-select,.el-textarea
    width: 100%;
    max-width: 400px;
  .el-input-number, .el-select
    .el-input
      width: 100%;
  .el-date-editor
    width: auto;
  .el-form-item:last-child
    margin-bottom: 0;
// 公共表单提交按纽条
.pub-form-submit-bar
  display: flex;
  padding-left: 140px;
  margin-top:10px;
  .el-button
    width:200px;
    margin-right: 20px;
    margin-left: 0;
    &:last-child
      margin-right: 0;
// 公共页面标题
.pub-page-title:not(.no-border)
  height: 55px;
  line-height: 55px;
  .title
    padding-left: 30px;
  .item
    border-radius: 50% !important;
    padding: 0 3px !important;
    background: #bbbbbb;
    color: #ffffff;
.pub-page-title.no-border
  height: 55px;
  line-height: 55px;
  .title
    padding-left: 30px;

// 公共列表过滤块
.pub-filter-box
  padding: 20px 30px;
  &.no-border
    border: none;
  .btn-bar
    display: flex;
    margin-bottom: 10px;
    line-height: 30px;
    .el-select
      .el-input__inner
        height:30px!important;
        line-height:30px;
    .el-button + .filter-search
      margin-left:10px;
    .filter-search
      .el-input__inner
        border-radius:0px;
        width:365px;
      .el-button 
        border-radius:0 2px 2px 0;
        background-image: linear-gradient(90deg,#158bfb 0%, #0c9ef7 100%), linear-gradient(#618afd, #618afd);
  .time-bar,.radio-bar,.mutex-check-bar
    .el-radio
      .el-radio__label
        color:#3a3d57;
    .el-checkbox
      .el-checkbox__label
        color:#3a3d57;
  .time-bar
    .el-date-editor
      height:30px;
      line-height:30px;
      padding:0 10px;
  .search-bar
    .el-input__inner
      height:30px;
      line-height: 30px;
  .filter-label
    flex: 0 0 70px;
    width: auto;
    font-size: 14px;
    text-align: left;
    margin-right: 10px;
    line-height: 30px;
// 公共列表包裹层
.pub-table-wrap
  padding: 10px  20px;
  .table-top-bar
    display: flex;
    .title
      padding-left: 20px;
      flex:  0 0 auto;
      align-self: center;
      &+.btn
        margin-left: 20px;
    .btn
      flex: 0 0 auto;
      min-width:80px;
      padding:0;
      text-align: center;
      font-size: 12px;
      height:36px;
      line-height:36px;
      align-self: center;
      // .el-button
      //   background:#f6f8fb;
      //   color:#3a3d57;
      //   box-sizing: border-box;
      //   border:1px solid #eaf0f8
    .count
      flex:1;
      align-self: center;
      text-align:right;
      color:#0084ff;
// 公共列表样式
.pub-table
  width: 100%;
  border-top: 1px solid #ebebeb;
  margin: 10px auto 20px;
  .el-table__header
    thead
      color: #666;
      font-size: 14px;
      line-height: 36px;
      font-weight: 500;
    th
      background-color:#f2f7f9;;
      padding:0;
  .table-btn-column
    .el-button
      &.el-button--text
        border:none;
        font-size:14px;
        color:#0084ff;
      &.no-line
        margin-left:0 !important;
        &:before
          display: none !important;
    .el-button + .el-button,
    .el-button + span > .el-button
      margin-left:5px;
      position:relative;
      &:before
        content:"";
        left:-5px;
        display:block;
        position:absolute;
        top:50%;
        margin-top:-7px;
        height:14px;
        width:1px;
        background:#0084ff
  .gray-bg
    background:#f2f7f9;
  .image-wrap
    flex: 0 0 auto;
    width: auto;
    margin-right: 10px;
    .response-image
      max-width: 150px;
      max-height: 150px;
      width: 100%;
      height: 100%;

.new-layout-main
  .pub-table
    border:none;
    .el-table__header
      th
        background-color:rgba(0,132,255,0.1);
        padding:0;
        color: #3a3d57;
        font-size: 14px;
        line-height: 36px;
        font-weight: 600;
    .el-table__body-wrapper
      td
        color:#3a3d57;
// 自适应图片大小
.response-image
  max-width: 100%;
  max-height: 100%;
.can-click
  color: #0084ff;
  cursor: pointer;
// 左边有竖线
.tips-text
  color: #E51C23;
  line-height: 36px;
.tips-bar
  padding-left: 20px;
  line-height: 36px;
  position: relative;
  &:after
    position: absolute;
    left: 0;
    top: 50%;
    content: '';
    display: block;
    height: 20px;
    width: 4px;
    background: #03a9fe;
    transform: translateY(-50%);
.new-tips-bar
  background:#f6f8fb;
  line-height:50px;
  padding-left:10px;
  width:100%;
  box-sizing: border-box;
  color:#8690ac
// 危险操作按钮
.danger-btn
  color:#999;
  &:hover
    color:#666;


.dialog-btn-bar
  text-align:  right;

.form-btn-bar
  display: flex;
  justify-content: center;
  .el-button,button
    &:last-child
      margin-left: 40px;
  

.basic-tooltip
  align-self: center;
  border-radius: 50%;
  padding: 0 3px;
  margin-left: 10px;
  height: 16px;
  width: 16px;
  background: #bbbbbb;
  color: #ffffff;
  &:hover
    background: #bbbbbb;
    color:#fff;



.el-input
  &.s-inner
    .el-input__inner
      padding:0 10px;
  &.m-inner
    .el-input__inner
      padding:0 5px;
  &.s-text
    .el-input-group__append,.el-input-group__prepend
      padding:0 10px;
  &.m-text
    .el-input-group__append,.el-input-group__prepend
      padding:0 5px;