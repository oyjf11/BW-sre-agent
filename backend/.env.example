# SRE Agent Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=OpsPilot
APP_ENV=dev
DEBUG=false

# LLM Provider: openai / minimax / deepseek
LLM_PROVIDER=minimax

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o

# MiniMax (if LLM_PROVIDER=minimax)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_MODEL=MiniMax-M2.5

# DeepSeek (if LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# Database
DATABASE_URL=sqlite+aiosqlite:///./opspilot.db

# HTTP
HTTP_TIMEOUT=30
SSE_TIMEOUT=300

# Security
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Tool Adapter (mock/real)
TOOL_ADAPTER_MODE=mock

# MySQL (real adapter, Alibaba Cloud RDS)
# MYSQL_HOST=rm-xxx.mysql.rds.aliyuncs.com
# MYSQL_PORT=3306
# MYSQL_USER=readonly
# MYSQL_PASSWORD=your_password
# MYSQL_DB=hoo_ai
# MYSQL_POOL_SIZE=5
# MYSQL_READONLY=true

# Kubernetes (real adapter)
# Leave K8S_ALLOWED_NAMESPACES empty to fail closed in real mode.
# Example:
# K8S_ALLOWED_NAMESPACES=["default","staging"]
K8S_CONFIG_PATH=
K8S_CONTEXT=
K8S_ALLOWED_NAMESPACES=[]

# Alibaba Cloud SLB (real adapter)
# ALIBABA_ACCESS_KEY_ID=your_ak_id
# ALIBABA_ACCESS_KEY_SECRET=your_ak_secret
# ALIBABA_REGION_ID=cn-hangzhou

# Alibaba Cloud CMS / K8s metrics (real adapter)
# K8S_CLUSTER_ID=your_cluster_id

# Alibaba Cloud OSS (real adapter)
# ALIBABA_OSS_BUCKET=your_bucket
# ALIBABA_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# ALIBABA_ACCESS_KEY_ID=your_ak_id
# ALIBABA_ACCESS_KEY_SECRET=your_ak_secret

# RAG knowledge retrieval
RAG_ENABLED=false
RAG_PERSIST_DIR=./storage/chroma
RAG_COLLECTION_NAME=opspilot_knowledge
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=80
RAG_RUNBOOK_DIR=./knowledge/runbooks
RAG_TOP_K=5
RAG_ENABLE_RERANKER=false
RAG_RERANKER_TOP_N=5

# Tracing provider: local / langsmith / langfuse
TRACING_PROVIDER=local
TRACING_PROJECT=opspilot
TRACING_BASE_URL=
TRACING_PUBLIC_BASE_URL=
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Logging
LOG_LEVEL=INFO
