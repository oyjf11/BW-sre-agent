{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "frontend-bug-orchestrator",
  "agent": {
    "frontend-bug-orchestrator": {
      "description": "Frontend bug workflow orchestrator. Dispatches reproduction, root cause, fix, verification and review stages without reading or editing code directly.",
      "mode": "primary",
      "temperature": 0,
      "prompt": "{file:.opencode/prompts/frontend-bug-orchestrator.md}",
      "permission": {
        "*": "deny",
        "skill": "allow",
        "question": "allow",
        "todo": "allow",
        "todowrite": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "task": {
          "*": "deny",
          "frontend-bug-reproducer": "allow",
          "frontend-bug-rootcasuse": "allow",
          "frontend-bug-fixer": "allow",
          "frontend-bug-reviewer": "allow"
        }
      }
    },
    "frontend-bug-reproducer": {
      "description": "Hidden frontend bug reproduction specialist. Establishes stable reproduction and collects direct evidence only.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.1,
      "prompt": "{file:.opencode/prompts/frontend-bug-reproducer.md}",
      "permission": {
        "*": "deny",
        "skill": "allow",
        "edit": "deny",
        "write": "deny",
        "task": "deny",
        "bash": {
          "*": "ask",
          "rg *": "allow",
          "grep *": "allow",
          "cat *": "allow",
          "sed *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "pnpm test*": "allow",
          "npm test*": "allow",
          "npm run test*": "allow",
          "pnpm vitest*": "allow",
          "npx vitest*": "allow"
        }
      }
    },
    "frontend-bug-rootcasuse": {
      "description": "Hidden frontend root cause analysis specialist. Uses reproduction evidence to trace code/data flow and verify hypotheses without modifying files.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.1,
      "prompt": "{file:.opencode/prompts/frontend-bug-rootcasuse.md}",
      "permission": {
        "*": "deny",
        "skill": "allow",
        "edit": "deny",
        "write": "deny",
        "task": "deny",
        "bash": {
          "*": "ask",
          "rg *": "allow",
          "grep *": "allow",
          "cat *": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "pnpm test*": "allow",
          "npm test*": "allow",
          "npm run test*": "allow",
          "pnpm vitest*": "allow",
          "npx vitest*": "allow"
        }
      }
    },
    "frontend-bug-fixer": {
      "description": "Hidden frontend bug fixer. Implements minimal fixes only after root cause is confirmed and modification scope is approved.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.1,
      "prompt": "{file:.opencode/prompts/frontend-bug-fixer.md}",
      "permission": {
        "*": "deny",
        "skill": "allow",
        "edit": "ask",
        "write": "ask",
        "task": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "pnpm lint*": "allow",
          "npm run lint*": "allow",
          "pnpm typecheck*": "allow",
          "npm run typecheck*": "allow",
          "pnpm test*": "allow",
          "npm test*": "allow",
          "npm run test*": "allow",
          "pnpm vitest*": "allow",
          "npx vitest*": "allow"
        }
      }
    },
    "frontend-bug-reviewer": {
      "description": "Hidden frontend bug fix reviewer. Read-only diff review against root cause, regression risk, scope, quality and tests.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0,
      "prompt": "{file:.opencode/prompts/frontend-bug-reviewer.md}",
      "permission": {
        "*": "deny",
        "skill": "allow",
        "edit": "deny",
        "write": "deny",
        "task": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "cat *": "allow",
          "pnpm test*": "allow",
          "npm test*": "allow",
          "npm run test*": "allow",
          "pnpm vitest*": "allow",
          "npx vitest*": "allow"
        }
      }
    }
  },
  "command": {
    "frontend-bug": {
      "description": "Run the controlled frontend bug repair workflow through frontend-bug-orchestrator.",
      "agent": "frontend-bug-orchestrator",
      "template": "Use frontend-bug-orchestrator to process this frontend bug under the staged state machine, contract, todo gates and subagent permissions. Bug input:\n\n$ARGUMENTS"
    }
  }
}
